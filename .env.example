# Anthropic API key for the LLM screener call.
ANTHROPIC_API_KEY=sk-ant-...

# Authorized-vs-unauthorized gate for POST /score. Comma-separated client API
# keys. EMPTY = auth OFF (fine for localhost / the LAN surface). Set a non-empty
# list BEFORE the public surface is unblocked; callers then present a matching
# key via `Authorization: Bearer <key>` or `X-API-Key`. /health stays open.
KAIROS_SCORER_API_KEYS=

# Model for the screener.
KAIROS_SCORER_MODEL=claude-sonnet-4-6

# Screener thinking depth / token spend: low | medium | high | max.
KAIROS_SCORER_EFFORT=medium

# Upper bound on screener output tokens.
KAIROS_SCORER_MAX_TOKENS=2048

# Arithmetic-baseline decision bands (score 0–100). Must satisfy
# apply ≥ maybe ≥ escalate_floor (below), else the process fails to start.
KAIROS_APPLY_THRESHOLD=65
KAIROS_MAYBE_THRESHOLD=35

# Min baseline score for `wide` to escalate a near-miss skip (just under the
# maybe band, where the LLM most often overturns the gate). Hard-gate skips
# (score 0) stay below it. Set == maybe threshold to disable near-miss escalation.
#KAIROS_ESCALATE_FLOOR=25

# Build provenance — set by CI at image build (e.g. the short git SHA).
KAIROS_BUILD_SHA=dev

# ── Deploy / topology (docker compose; see infra/README.md) ──────────────────
# Pick a local topology by pointing compose at its self-contained file:
#   standalone (this host owns :80/:443):
#     docker compose -f infra/local/standalone/docker-compose.yml up -d --wait
#   cluster (shared edge owns the ports, routes by Host):
#     docker compose -f infra/local/cluster/docker-compose.yml up -d --wait

# STANDALONE only — Caddy listen address + published host ports.
#   :80 → plain HTTP any Host;  a bare domain → automatic HTTPS.
SCORER_SITE_ADDRESS=:80
SCORER_HTTP_PORT=80
SCORER_HTTPS_PORT=443
