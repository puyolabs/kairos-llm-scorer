#!/bin/sh
# Pre-commit: fast lint + format-check, scoped to the staged Python files only
# (the lint-staged idea). No mutation — fix with `make fix`.
staged=$(git diff --cached --name-only --diff-filter=ACM -- '*.py')
[ -z "$staged" ] && exit 0

# &&-chained so the first failure aborts the commit (non-zero exit blocks it).
echo "$staged" | xargs uv run ruff check &&
  echo "$staged" | xargs uv run ruff format --check
